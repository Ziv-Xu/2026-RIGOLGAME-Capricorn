#include "usart3.h"
      /*
      u8 Usart2_Receive_buf[1];  // USART2 接收缓冲区（代码中未实际使用）
      u8 Usart2_Receive;          // USART2 接收数据（代码中未实际使用）
      */

//蓝牙所用的串口3
u8 Usart3_Receive_buf[1];  // USART3 接收缓冲区（仅存 1 字节）。在主函数中初始化的时候需要指出，如HAL_UART_Receive_IT(&huart3, Usart3_Receive_buf, sizeof(Usart3_Receive_buf));
u8 Usart3_Receive;          // USART3 接收到的单字节数据

void HAL_UART_RxCpltCallback(UART_HandleTypeDef *UartHandle)// 串口接收完成回调函数（串口每收到 1 字节数据就会自动调用此函数）
{
	
			if(UartHandle->Instance == USART3)
			{
						static	int uart_receive=0;
						static u8 Flag_PID,i,j,Receive[50];
						static float Data;
						uart_receive=Usart3_Receive_buf[0]; 
						Usart3_Receive=uart_receive;
            //下面四个if是一起的，优先判断模式，之后再判断
            if(uart_receive == 0x59)  Flag_velocity = 2;  // 模式 2（如“快速模式”）
            if(uart_receive == 0x58)  Flag_velocity = 1;  // 模式 1（如“慢速模式”）
						  //两种控制，上面两个模式会进入uart_receive>10中的最后一个else，保证不会因为换挡让车停下来
						if(uart_receive>10)
						{			
									if(uart_receive==0x5A)	    Flag_front=0,Flag_back=0,Flag_Left=0,Flag_Right=0;
									else if(uart_receive==0x41)	Flag_front=1,Flag_back=0,Flag_Left=0,Flag_Right=0;
									else if(uart_receive==0x45)	Flag_front=0,Flag_back=1,Flag_Left=0,Flag_Right=0;
									else if(uart_receive==0x42||uart_receive==0x43||uart_receive==0x44)	
																							Flag_front=0,Flag_back=0,Flag_Left=0,Flag_Right=1;
									else if(uart_receive==0x46||uart_receive==0x47||uart_receive==0x48)	    
																							Flag_front=0,Flag_back=0,Flag_Left=1,Flag_Right=0;
									else Flag_front=0,Flag_back=0,Flag_Left=0,Flag_Right=0;
						}
						if(uart_receive<10)
						{			
									if(uart_receive==0x00)	Flag_front=0,Flag_back=0,Flag_Left=0,Flag_Right=0;
									else if(uart_receive==0x01)	Flag_front=1,Flag_back=0,Flag_Left=0,Flag_Right=0;
									else if(uart_receive==0x05)	Flag_front=0,Flag_back=1,Flag_Left=0,Flag_Right=0;
									else if(uart_receive==0x02||uart_receive==0x03||uart_receive==0x04)	
																				Flag_front=0,Flag_back=0,Flag_Left=0,Flag_Right=1;
									else if(uart_receive==0x06||uart_receive==0x07||uart_receive==0x08)	    
																				Flag_front=0,Flag_back=0,Flag_Left=1,Flag_Right=0;
									else Flag_front=0,Flag_back=0,Flag_Left=0,Flag_Right=0;
						}	

						//PID在线调参
            //数据，每一次中断就会有一个字节通过串口送过来，如果是在进行调参，应该就是先检测帧头，然后是数据，后为帧尾，最后解析数据
            if(Usart3_Receive == 0x7B) Flag_PID = 1;  // 收到帧头（0x7B），开始接收 PID 数据
            if(Usart3_Receive == 0x7D) Flag_PID = 2;  // 收到帧尾（0x7D），开始解析 PID 数据

						 if(Flag_PID==1)
						 {
								Receive[i]=Usart3_Receive;
								i++;
						 }
						 if(Flag_PID==2)
						 {
								if(Receive[3]==0x50) 				 PID_Send=1;// 特殊指令：请求上传当前 PID 参数
                //将接收到的“字符数字”转换为“浮点数”
								else if(Receive[1]!=0x23) // 若不是特殊标记，解析参数
								{								
    									for(j=i;j>=4;j--)
      									{
      										Data+=(Receive[j-1]-48)*pow(10,i-j);
      									}
                      //根据指令类型，将 Data 赋值给对应的 PID 参数
    									switch(Receive[1])
      									{
      										case 0x30:  Balance_Kp=Data;break;
      										case 0x31:  Balance_Kd=Data;break;
      										case 0x32:  Velocity_Kp=Data;break;
      										case 0x33:  Velocity_Ki=Data;break;
      										case 0x34:  Turn_Kp=Data;break; 
      										case 0x35:  Turn_Kd=Data;break; 
      										case 0x36:  break;
      										case 0x37:  break;
      										case 0x38:  break;
      									}
								}			 
                //复位状态变量，准备下一次接收
									Flag_PID=0;
									i=0;
									j=0;
									Data=0;
									memset(Receive, 0, sizeof(u8)*50);// 清空 Receive 数组
						 }
						 
						HAL_UART_Receive_IT(&huart3,Usart3_Receive_buf,sizeof(Usart3_Receive_buf));//重新开启接收中断.HAL 库的串口中断接收是 “单次触发” 的，因此每次接收完成后，必须重新调用此函数，才能继续接收下一个字节。
			}
}
