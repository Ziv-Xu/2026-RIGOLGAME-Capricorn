  // 读取一次 HX711 原始值
// gain: 128/64/32
long HX711_Read(uint8_t gain)
{
    uint32_t data = 0;
    uint8_t i;

    // 等待转换完成
    while(HAL_GPIO_ReadPin(HX711_DOUT_PORT, HX711_DOUT_PIN) == GPIO_PIN_SET);

    // 读 24 位数据，SCK先拉高，读取DOUT数据写入data，之后拉低
    for(i=0; i<24; i++)
    {
        HAL_GPIO_WritePin(HX711_SCK_PORT, HX711_SCK_PIN, GPIO_PIN_SET);
        data <<= 1;
        HAL_GPIO_WritePin(HX711_SCK_PORT, HX711_SCK_PIN, GPIO_PIN_RESET);

        if(HAL_GPIO_ReadPin(HX711_DOUT_PORT, HX711_DOUT_PIN))
            data++;
      /*
        HAL_GPIO_WritePin(HX711_SCK_PORT, HX711_SCK_PIN, GPIO_PIN_SET);
        data <<= 1;
        if(HAL_GPIO_ReadPin(HX711_DOUT_PORT, HX711_DOUT_PIN))data++;
        HAL_GPIO_WritePin(HX711_SCK_PORT, HX711_SCK_PIN, GPIO_PIN_RESET);
        这样是错误的写法，因为HX711 的官方规定时序是：SCK 上升沿 输出数据 → SCK 下降沿 锁存 → 单片机读取
      */
    }

    // 第25~27个脉冲设置增益，一般来说，电子秤是128倍，也就是24+1，gain=1
    for(i=0; i<gain; i++)
    {
        HAL_GPIO_WritePin(HX711_SCK_PORT, HX711_SCK_PIN, GPIO_PIN_SET);
        HAL_GPIO_WritePin(HX711_SCK_PORT, HX711_SCK_PIN, GPIO_PIN_RESET);
    }

    // 24位有符号数扩展，因为检测到的24位数据有符号，也就是首位决定正负，所以转化为32位时需要通过操作使其变成可以被识别的负
    if(data & 0x800000)
        data |= 0xFF000000;

    return (long)data;
}
//多次采样取平均
long HX711_Read_Average(uint8_t times)
{
    long sum = 0;
    for(uint8_t i=0; i<times; i++)
    {
        sum += HX711_Read(1);  // 正确：1 个脉冲 = 增益128
        HAL_Delay(1);//直接使用DELAY可能会卡死？现在还不知道
    }
    return sum / times;
}

long  hx711_offset = 0;  // 去皮偏移
float hx711_coef   = 0.0015f; // 校准系数（也就是单位换算，之后进行换算）
// 去皮函数
void HX711_Tare(void)
{
    hx711_offset = HX711_Read_Average(20);
}
// 获取重量 g
float HX711_Get_Weight(void)
{
    long val = HX711_Read_Average(10) - hx711_offset;
    return val * hx711_coef;
}
  
