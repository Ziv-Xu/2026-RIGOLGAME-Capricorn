/*
 * 函数：IR1_Read，IR2_Read
 * 功能：读取红外1的，2电平，返回 0 或 1
 */
uint8_t IR1_Read(void){return HAL_GPIO_ReadPin(IR1_GPIO_PORT, IR1_PIN);}
uint8_t IR2_Read(void){return HAL_GPIO_ReadPin(IR2_GPIO_PORT, IR2_PIN);}

/*
 * 函数：IR_Get_State
 * 功能：获取两个红外的组合状态，解析并且判断物块
 * 返回：IR_StateTypeDef 类型（0~3）
 */
IR_StateTypeDef IR_Get_State(void)
{
    //接受读出信号
    uint8_t ir1 = IR1_Read();
    uint8_t ir2 = IR2_Read();

    // 组合成 2 位二进制：ir1 是高位，ir2 是低位
    if (ir1 == 0 && ir2 == 0) return IR_STATE_00;//物块1
    if (ir1 == 0 && ir2 == 1) return IR_STATE_01;//物块2
    if (ir1 == 1 && ir2 == 0) return IR_STATE_10;//物块3
    return IR_STATE_11; // 默认
}





















