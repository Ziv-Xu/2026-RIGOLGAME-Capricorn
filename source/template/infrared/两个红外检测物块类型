/*
项目采用两个红外来检测三种不同的物块，所以需要初始化两个GPIO引脚
在CubeMX配置两个引脚为上拉输入（或者根据实际情况其他的？？）
由于绝大多数红外模块：遮挡 = 低电平 0，无遮挡 = 高电平 1
*/

#include "stm32f1xx_hal.h"  // 根据你的芯片型号改，如 f4xx、f7xx、g0xx 等


/* -------------------------- 引脚配置 -------------------------- */
// 红外模块 1 引脚
#define IR1_PIN        GPIO_PIN_0
#define IR1_GPIO_PORT  GPIOC
#define IR1_GPIO_CLK   __HAL_RCC_GPIOA_CLK_ENABLE()

// 红外模块 2 引脚
#define IR2_PIN        GPIO_PIN_1
#define IR2_GPIO_PORT  GPIOC
#define IR2_GPIO_CLK   __HAL_RCC_GPIOA_CLK_ENABLE()




// 红外组合状态枚举，遮挡 = 低电平 0，无遮挡 = 高电平 1
typedef enum {
    IR_STATE_00 = 0,  // 00：都检测，对应物块1
    IR_STATE_01 = 1,  // 01：仅 IR2 检测，对应物块2
    IR_STATE_10 = 2,  // 10：仅 IR1 检测，对应物块3
    IR_STATE_11 = 3   // 11：都未检测
} IR_StateTypeDef;



